# ── Database (Supabase PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxxx.supabase.co:5432/postgres

# ── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string
JWT_EXPIRY=7d

# ── Google SMTP ──────────────────────────────────────────────────────────────
# Use an App Password from https://myaccount.google.com/apppasswords
# (Google account must have 2-Step Verification enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
EMAIL_FROM=SwiftCargo <your@gmail.com>

# ── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-app.up.railway.app
APP_URL=https://your-app.up.railway.app
PORT=3000

# ── Admin seed account ───────────────────────────────────────────────────────
ADMIN_EMAIL=admin@swiftcargo.co.ke
ADMIN_PASSWORD=change_this_immediately
